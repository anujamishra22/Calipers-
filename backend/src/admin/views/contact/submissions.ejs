<% var section = 'Contact'; %>
<%- include('../partials/header') %>

<div class="card">
  <% if (!rows.length) { %>
    <div class="empty">
      <div class="empty-mark">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
          <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
        </svg>
      </div>
      <p>No submissions yet.</p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>When</th>
          <th>Name</th>
          <th>Email</th>
          <th>Message</th>
          <th>Status</th>
          <th style="width:1%; text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function (r) { %>
        <tr>
          <td><code><%= new Date(r.createdAt).toISOString().slice(0, 16).replace('T', ' ') %></code></td>
          <td style="font-weight:600; color:var(--text-strong)"><%= r.name %></td>
          <td><a href="mailto:<%= r.email %>"><%= r.email %></a></td>
          <td style="max-width:280px; white-space:pre-wrap; color:var(--muted); font-size:13px"><%= r.message %></td>
          <td>
            <span class="pill <%= r.status === 'NEW' ? 'pill-accent' : (r.status === 'ARCHIVED' ? 'pill-off' : 'pill-on') %>">
              <%= r.status %>
            </span>
          </td>
          <td>
            <div class="row-actions" style="justify-content:flex-end">
              <% if (r.status !== 'READ') { %>
              <form method="post" action="/admin/contact/submissions/<%= r.id %>/status" style="display:inline">
                <input type="hidden" name="status" value="READ" />
                <button type="submit" class="secondary btn-sm">Mark read</button>
              </form>
              <% } %>
              <% if (r.status !== 'ARCHIVED') { %>
              <form method="post" action="/admin/contact/submissions/<%= r.id %>/status" style="display:inline">
                <input type="hidden" name="status" value="ARCHIVED" />
                <button type="submit" class="secondary btn-sm">Archive</button>
              </form>
              <% } %>
              <form method="post" action="/admin/contact/submissions/<%= r.id %>/delete" style="display:inline" onsubmit="return confirm('Delete?');">
                <button type="submit" class="danger btn-sm">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
